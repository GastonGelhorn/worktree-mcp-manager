{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Worktree MCP Manager",
  "version": "0.1.0",
  "identifier": "com.gaston.worktree-mcp",
  "build": {
    "beforeDevCommand": "cargo build -p worktree-cli && cd mcp-server && npx tsc && cd .. && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "sh scripts/build-prod.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Worktree MCP Manager",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../mcp-server/dist/index.mjs"
    ],
    "externalBin": [
      "bin/worktree-cli",
      "bin/mcp-server"
    ]
  }
}